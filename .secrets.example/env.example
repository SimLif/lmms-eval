# Med-Eval Secrets — copy to ../.secrets/env and fill in values
# Usage: source .secrets/env

# Proxy (Baidu internal)
export http_proxy="http://user:password@proxy-host:port"
export https_proxy="$http_proxy"
export HTTP_PROXY="$http_proxy"
export HTTPS_PROXY="$http_proxy"
export no_proxy="localhost,127.0.0.1"
export NO_PROXY="$no_proxy"

# HuggingFace
export HF_TOKEN="hf_xxxxxxxxxxxxxxxxxxxx"

# WandB
export WANDB_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Google Sheets service account
export GOOGLE_APPLICATION_CREDENTIALS=".secrets/google_credentials.json"
